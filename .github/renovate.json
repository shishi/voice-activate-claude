{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Asia/Tokyo)"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 6am on monday"
    ]
  },
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "nix"
      ],
      "groupName": "nix flake inputs",
      "commitMessageTopic": "nix flake input {{depName}}"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "pinDigests": true,
      "commitMessageTopic": "GitHub Action {{depName}}"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "python dependencies"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "python major updates",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ],
  "minimumReleaseAge": "3 days",
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "0",
    "automerge": true,
    "automergeType": "pr",
    "platformAutomerge": true
  }
}
